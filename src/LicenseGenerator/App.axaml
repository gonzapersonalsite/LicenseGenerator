<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:LicenseGenerator"
             x:Class="LicenseGenerator.App"
             RequestedThemeVariant="Dark">
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <SolidColorBrush x:Key="SystemControlErrorTextForegroundBrush" Color="Red"/>
        
        <!-- Standard Colors -->
        <SolidColorBrush x:Key="ColorDanger" Color="#F44336"/>
        <SolidColorBrush x:Key="ColorSuccess" Color="#4CAF50"/>
        <SolidColorBrush x:Key="ColorWarning" Color="#FF9800"/>
        <SolidColorBrush x:Key="ColorPrimary" Color="#2196F3"/>
        <SolidColorBrush x:Key="ColorNeutral" Color="#757575"/>
        <SolidColorBrush x:Key="ColorWhite" Color="#FFFFFF"/>

        <!-- Font Sizes -->
        <x:Double x:Key="FontSizeTiny">10</x:Double>
        <x:Double x:Key="FontSizeSmall">12</x:Double>
        <x:Double x:Key="FontSizeNormal">14</x:Double>
        <x:Double x:Key="FontSizeMedium">16</x:Double>
        <x:Double x:Key="FontSizeLarge">18</x:Double>
        <x:Double x:Key="FontSizeExtraLarge">24</x:Double>
        <x:Double x:Key="FontSizeHuge">28</x:Double>
        <x:Double x:Key="FontSizeExtraHuge">36</x:Double>

        <!-- Navigation & UI Icons -->
        <StreamGeometry x:Key="LineHorizontal3Regular">M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z</StreamGeometry>
        <StreamGeometry x:Key="HomeRegular">M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z</StreamGeometry>
        <StreamGeometry x:Key="AppsRegular">M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z</StreamGeometry>
        <StreamGeometry x:Key="KeyRegular">M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z</StreamGeometry>
        <StreamGeometry x:Key="HistoryRegular">M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z</StreamGeometry>
        <StreamGeometry x:Key="SettingsRegular">M12 15.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7zM19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.31-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65A.488.488 0 0 0 14 3h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.31.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65z</StreamGeometry>
        
        <!-- Utility Icons -->
        <StreamGeometry x:Key="CopyRegular">M19 2h-4.18C14.4.84 13.3 0 12 0c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm7 18H5V4h2v3h10V4h2v16z</StreamGeometry>
        <StreamGeometry x:Key="FolderRegular">M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z</StreamGeometry>
        <StreamGeometry x:Key="DeleteRegular">M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z</StreamGeometry>
        <StreamGeometry x:Key="ShieldRegular">M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z</StreamGeometry>
        <StreamGeometry x:Key="CheckRegular">M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z</StreamGeometry>
        <StreamGeometry x:Key="ExportRegular">M9 16h6v-6h4l-7-7-7 7h4v6zM5 18h14v2H5v-2z</StreamGeometry>
        <StreamGeometry x:Key="ImportRegular">M19 9h-4V3H9v6H5l7 7 7-7zM5 18h14v2H5v-2z</StreamGeometry>
        <StreamGeometry x:Key="AppearanceRegular">M21 12.35c0 5.31-4.32 9.62-9.62 9.62-5.3 0-9.62-4.31-9.62-9.62h1.54C3.3 17.14 7.21 21.05 12 21.05s8.7-3.91 8.7-8.7c0-2.43-.99-4.62-2.58-6.19l1.09-1.09C20.84 6.78 22 9.4 22 12.35zM12.35 1c-5.31 0-9.62 4.31-9.62 9.62h1.54c0-4.64 3.77-8.41 8.41-8.41 2.37 0 4.51.98 6.05 2.56l1.09-1.09C18.17 2.15 15.39 1 12.35 1z</StreamGeometry>
        <StreamGeometry x:Key="PackageRegular">M21 16.5C21 16.88 20.79 17.21 20.47 17.38L12.57 21.82C12.41 21.94 12.21 22 12 22C11.79 22 11.59 21.94 11.43 21.82L3.53 17.38C3.21 17.21 3 16.88 3 16.5V7.5C3 7.12 3.21 6.79 3.53 6.62L11.43 2.18C11.59 2.06 11.79 2 12 2C12.21 2 12.41 2.06 12.57 2.18L20.47 6.62C20.79 6.79 21 7.12 21 7.5V16.5Z</StreamGeometry>
        <StreamGeometry x:Key="InfoRegular">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z</StreamGeometry>
        <StreamGeometry x:Key="HeartRegular">M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z</StreamGeometry>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <StyleInclude Source="avares://LicenseGenerator/Styles/PaginatedListStyle.axaml"/>

        <!-- Default Window Font Size -->
        <Style Selector="Window">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        </Style>

        <!-- DataGrid Font Sizes -->
        <Style Selector="DataGrid">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="DataGridColumnHeader TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        </Style>
        <Style Selector="DataGridCell TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        </Style>

        <!-- General Inputs -->
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeNormal}"/>
        </Style>

        <!-- Primary (Blue) - Secondary Actions -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="{DynamicResource ColorPrimary}"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorWhite}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorWhite}"/>
        </Style>

        <!-- Success (Green) - Principal Actions / Creation / Copy -->
        <Style Selector="Button.Success">
            <Setter Property="Background" Value="{DynamicResource ColorSuccess}"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorWhite}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Success:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#388E3C"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorWhite}"/>
        </Style>

        <!-- Danger (Red) - Destructive Actions -->
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="{DynamicResource ColorDanger}"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorWhite}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorWhite}"/>
        </Style>

        <!-- Icon Only Helper - Ensures Proportional Scaling and Vertical Parity -->
        <Style Selector="Button.IconOnly">
            <!-- Padding vertical should match (6px), horizontal slightly more for square feel -->
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.IconOnly PathIcon">
            <!-- Icon size based on FontSize to match text height scaling -->
            <Setter Property="Width" Value="{Binding $parent[Button].FontSize}"/>
            <Setter Property="Height" Value="{Binding $parent[Button].FontSize}"/>
        </Style>

        <!-- Secondary (Outline) -->
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorNeutral}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ColorNeutral}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ColorNeutral}"/>
            <Setter Property="Foreground" Value="{DynamicResource ColorWhite}"/>
        </Style>
    </Application.Styles>
</Application>
